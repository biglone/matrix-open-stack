PUID=1000
PGID=1000
MATRIX_PORT=6167
MATRIX_CONTROL_PORT=6180
MATRIX_SERVER_NAME=matrix.example.com

# Conduwuit release version used by scripts/download_conduwuit.sh
CONDUWUIT_VERSION=v0.4.6

# Matrix admin auth for control API (choose one option).
MATRIX_ADMIN_USER=admin
MATRIX_ADMIN_PASSWORD=change-me
MATRIX_ADMIN_TOKEN=

# Protect /api endpoints (recommended).
CONTROL_API_TOKEN=change-me-to-a-long-random-token

# If true, /api/bots may return bot access_token in response.
EXPOSE_BOT_ACCESS_TOKEN=false

# Bot creation mode:
# - disabled (recommended): block /api/bots and use scripts/create_bot_secure.sh
# - legacy_register: use Matrix /register API (requires allow_registration)
BOT_CREATE_MODE=disabled
