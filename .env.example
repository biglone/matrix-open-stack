PUID=1000
PGID=1000
DOCKER_GID=979
MATRIX_PORT=6167
MATRIX_CONTROL_PORT=6180
MATRIX_SERVER_NAME=matrix.example.com

# Conduwuit release version used by scripts/download_conduwuit.sh
CONDUWUIT_VERSION=v0.4.6

# Matrix admin auth for control API (choose one option).
MATRIX_ADMIN_USER=admin
MATRIX_ADMIN_PASSWORD=change-me
MATRIX_ADMIN_TOKEN=

# Protect /api endpoints (recommended).
CONTROL_API_TOKEN=change-me-to-a-long-random-token

# If true, /api/bots may return bot access_token in response.
EXPOSE_BOT_ACCESS_TOKEN=false
EXPOSE_USER_ACCESS_TOKEN=false

# Bot creation mode:
# - disabled (recommended): block /api/bots and use scripts/create_bot_secure.sh
# - legacy_register: use Matrix /register API (requires allow_registration)
BOT_CREATE_MODE=disabled

# User creation mode:
# - disabled (recommended): block /api/users and use scripts/create_user_secure.sh
# - legacy_register: use Matrix /register API (requires allow_registration)
USER_CREATE_MODE=disabled

# Audit and invite throttling
AUDIT_LOG_PATH=/var/log/matrix-control/audit.log
FULL_USERS_SNAPSHOT_PATH=/var/log/matrix-control/full-users-snapshot.json
BOT_STATE_PATH=/var/log/matrix-control/bot-state.json
USER_STATE_PATH=/var/log/matrix-control/user-state.json
INVITE_RATE_LIMIT_WINDOW_SECONDS=60
INVITE_RATE_LIMIT_MAX=12

# Runtime restart API (disabled by default, requires docker.sock mount permissions).
RESTART_API_MODE=disabled
DOCKER_SOCKET_PATH=/var/run/docker.sock
COMPOSE_PROJECT_NAME=matrix-open-stack
RESTART_TIMEOUT_SECONDS=20

# Temporary registration window API from admin UI (disabled by default).
# When enabled, control-plane can temporarily set allow_registration=true and auto-close later.
REGISTRATION_WINDOW_API_MODE=disabled
REGISTRATION_WINDOW_DEFAULT_MINUTES=10
REGISTRATION_WINDOW_MAX_MINUTES=60
REGISTRATION_WINDOW_STATE_PATH=/var/log/matrix-control/registration-window-state.json

# Absolute host path of this repository, required for registration window operations.
STACK_HOST_PATH=/home/Biglone/workspace/matrix-open-stack

# Helper image used by control-plane to edit host config through docker socket.
HOST_HELPER_IMAGE=local/matrix-control-api:0.1.0
