# Security-first template for matrix-open-stack
# Usage:
#   cp .env.secure.template .env

PUID=1000
PGID=1000

# Local bind ports (localhost only)
MATRIX_PORT=6167
MATRIX_CONTROL_PORT=6180

# Public Matrix domain (must match conf/conduwuit.toml: server_name)
MATRIX_SERVER_NAME=matrix.biglone.tech

# Conduwuit release used by scripts/download_conduwuit.sh
CONDUWUIT_VERSION=v0.4.6

# Matrix admin auth for control API
# Option A (recommended): admin username + password
MATRIX_ADMIN_USER=admin
MATRIX_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Option B: admin access token (if set, Option A can be left empty)
MATRIX_ADMIN_TOKEN=

# Control API token (required, long random string)
# Generate:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
CONTROL_API_TOKEN=REPLACE_WITH_LONG_RANDOM_TOKEN

# Keep token exposure disabled
EXPOSE_BOT_ACCESS_TOKEN=false
EXPOSE_USER_ACCESS_TOKEN=false

# Security-first: disable API bot creation
BOT_CREATE_MODE=disabled

# Security-first: disable API user creation
USER_CREATE_MODE=disabled

# Audit and throttling
AUDIT_LOG_PATH=/var/log/matrix-control/audit.log
FULL_USERS_SNAPSHOT_PATH=/var/log/matrix-control/full-users-snapshot.json
BOT_STATE_PATH=/var/log/matrix-control/bot-state.json
USER_STATE_PATH=/var/log/matrix-control/user-state.json
INVITE_RATE_LIMIT_WINDOW_SECONDS=60
INVITE_RATE_LIMIT_MAX=12
